# Copy to .env.local and fill in (Next.js auto-loads .env.local; it is gitignored).
# In Vercel, set this per environment (Preview for the demo, Production for prod):
#   vercel env add OPENAI_API_KEY preview
#   vercel env add OPENAI_API_KEY production

# Required — used for embeddings (text-embedding-3-small) and chat (gpt-4o-mini).
OPENAI_API_KEY=

# Optional — selects the vector store backend.
#   unset / anything else → in-memory MemoryStore (default; resets on server restart)
#   "pg"                  → PgVectorStore (requires DATABASE_URL)
VECTOR_STORE=

# Required only when VECTOR_STORE=pg.
# Postgres connection string with the `vector` extension enabled (e.g. Supabase).
# Schema lives in db/schema.sql — run it once before the first upload.
DATABASE_URL=
